{
  "name": "vyotiq",
  "version": "0.1.0",
  "private": true,
  "description": "Vyotiq — Asynchronous AI Orchestrator (Agent V). A local-first private AI desktop app.",
  "author": "Vyotiq",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "flip-fuses": "node scripts/flipFuses.mjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:publish": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@ast-grep/napi": "^0.43.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lsp-client": "^6.2.5",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@photostructure/sqlite-vec": "^1.1.1",
    "@react-symbols/icons": "^1.4.1",
    "@tanstack/react-virtual": "^3.14.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "^3.4.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.16.0",
    "node-pty": "^1.1.0",
    "pyright": "^1.1.410",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "remend": "^1.3.0",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^41.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^6.0.0-beta.1",
    "happy-dom": "^20.9.0",
    "knip": "^6.12.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  },
  "allowScripts": {
    "electron@41.5.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true,
    "node-pty@1.1.0": true,
    "@ast-grep/cli@0.43.0": true
  }
}
