{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main/index.ts",
    "src/main/preload/preload.ts",
    "src/renderer/main.tsx",
    "electron.vite.config.ts",
    "tests/**/*.test.{ts,tsx}",
    "tests/setup/*.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx}"
  ],
  "paths": {
    "@shared/*": ["src/shared/*"],
    "@main/*": ["src/main/*"],
    "@renderer/*": ["src/renderer/*"]
  },
  "ignoreExportsUsedInFile": true,
  "ignore": [
    "src/main/types/raw.d.ts",
    "src/renderer/types/assets.d.ts"
  ],
  "ignoreIssues": {
    "src/shared/types/**": ["exports", "types"],
    "src/shared/settings/**": ["exports", "types"]
  },
  "ignoreDependencies": [
    "@fontsource-variable/geist",
    "@fontsource-variable/geist-mono",
    "pyright",
    "tailwindcss",
    "typescript-language-server"
  ]
}
