{
  "extends": "./tsconfig.web.json",
  "compilerOptions": {
    "types": [
      "node",
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "paths": {
      "@shared/*": [
        "./src/shared/*"
      ],
      "@main/*": [
        "./src/main/*"
      ],
      "@renderer/*": [
        "./src/renderer/*"
      ]
    }
  },
  "include": [
    "tests/**/*",
    "src/**/*",
    "vitest.config.ts"
  ]
}